# Telegram
TELEGRAM_BOT_TOKEN=        # от @BotFather
ADMIN_ID=                  # твой Telegram user_id (узнать у @userinfobot)
MINI_APP_URL=              # URL веб-приложения (после деплоя)

# Anthropic
ANTHROPIC_API_KEY=         # от console.anthropic.com

# Trello
TRELLO_API_KEY=            # от https://trello.com/app-key
TRELLO_TOKEN=              # там же → "Token"
TRELLO_BOARD_ID=           # ID доски из URL: trello.com/b/BOARD_ID/...

# База данных
DB_PATH=./data/tasks.db

# Сервер
PORT=3001
APP_URL=                   # https://твой-домен.duckdns.org

# Auth
JWT_SECRET=                # любая длинная случайная строка (openssl rand -hex 32)
PASSKEY_RP_NAME=           # "Task Dispatcher"
PASSKEY_RP_ID=             # твой домен без https: (например: myapp.duckdns.org)

# Trello polling интервал (минуты)
TRELLO_POLL_INTERVAL=5
